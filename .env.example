# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env

# Application
APP_NAME=AI-Assisted EMS Triage System
ENVIRONMENT=development
DEBUG=true

# Security (set a strong random value in real deployments)
SECRET_KEY=replace-with-a-secure-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOW_REGISTRATION=true

# LLM enrichment (optional, via local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
QWEN_MODEL_NAME=qwen3:14b

# Speech recognition (NeMo ASR)
NEMO_MODEL_PATH=models/FastConformer-Arabic-SADA-Finetune-baseline-v1_final.nemo
ASR_DECODER_TYPE=rnnt
ASR_DEVICE=auto
